# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — never expose to browser

# Stripe (hosted checkout — no Stripe Elements)
STRIPE_SECRET_KEY=sk_live_...                      # SERVER ONLY
STRIPE_WEBHOOK_SECRET=whsec_...                    # SERVER ONLY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Resend (transactional email)
RESEND_API_KEY=re_...                              # SERVER ONLY

# Anthropic (document generation)
ANTHROPIC_API_KEY=sk-ant-...                       # SERVER ONLY

# App
NEXT_PUBLIC_APP_URL=https://readypack.co.uk
